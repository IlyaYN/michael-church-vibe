---
import '../styles/global.css'; 

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ru" class="scroll-smooth">
        <head>
                <meta charset="UTF-8" />
                <meta name="description" content="Официальный сайт Храма Архангела Михаила в мкр. Заветы Ильича (г. Пушкино). Расписание богослужений, новости прихода, подача записок онлайн." />
                <meta name="keywords" content="Храм Архангела Михаила Пушкино, Заветы Ильича храм, православный храм Пушкино, расписание богослужений, подать записки онлайн" />
                <meta name="viewport" content="width=device-width" />
                <meta name="generator" content={Astro.generator} />
                
                {/* Иконка для браузера и Яндекса */}
                <link rel="icon" type="image/jpeg" href="/images/favicon.jpg" />
                {/* Иконка для Apple/Android */}
                <link rel="apple-touch-icon" href="/images/favicon.jpg" />
        
                <title>{title} | Храм Архангела Михаила</title>
                <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet">
            </head>
    
    <body class="font-['Manrope'] bg-slate-50 text-slate-900 leading-normal animate-[fadeIn_0.5s_ease-out] relative min-h-screen flex flex-col">
        
        {/* Фоновое изображение */}
        <div class="fixed inset-0 w-full h-full opacity-25 pointer-events-none mix-blend-multiply z-0">
            <img src="/images/sketch-dome.jpg" alt="" class="w-full h-full object-cover object-center">
        </div>

        {/* Контейнер для всего контента (занимает минимум высоту экрана) */}
        <div class="relative z-10 flex flex-col min-h-screen w-full">
          
            {/* Основной контент страницы (flex-grow выталкивает футер вниз) */}
            <main class="flex-grow">
                <slot />
            </main>

            {/* Аккуратный подвал (футер) */}
            <footer class="border-t border-slate-200 bg-white/60 backdrop-blur-md py-6 mt-10">
                <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-4">
                  
                    {/* Левая часть: Копирайт храма */}
                    <div class="text-slate-500 text-sm text-center md:text-left">
                        © <span id="current-year"></span> Храм Архангела Михаила мкр. Заветы Ильича.<br class="hidden md:block"/> Все права защищены.
                    </div>

                    {/* Правая часть: Ссылка на твой GitHub (только иконка) */}
                    <a href="https://github.com/IlyaYN" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-slate-800 transition-colors" aria-label="GitHub проекта" title="GitHub">
                        {/* SVG-код иконки GitHub */}
                        <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current" aria-hidden="true">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                        </svg>
                    </a>

                </div>
            </footer>
        </div>

        {/* Скрипт для автоматической подстановки года */}
        <script is:inline>
            const yearEl = document.getElementById('current-year');
            if (yearEl) yearEl.textContent = new Date().getFullYear().toString();
        </script>

    </body>
</html>

<style is:global>
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>