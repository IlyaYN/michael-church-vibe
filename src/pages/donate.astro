---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

// 1. НАСТРОЙКИ GOOGLE ТАБЛИЦЫ (Берем ID Админки из сейфа .env)
const SHEET_ID = import.meta.env.GOOGLE_SHEET_ADMIN_ID;
const TAB_NAME = 'Donations'; 
const URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${TAB_NAME}`;

let dynamicDonations = [];
// Стандартный текст подзаголовка (если в таблице его не изменят)
let pageSubtitle = "«Доброхотно дающего любит Бог». Ваша жертва идет на поддержание благолепия дома Божия и социальные проекты прихода.";

try {
  const response = await fetch(URL);
  const text = await response.text();
  const jsonString = text.substring(text.indexOf('{'), text.lastIndexOf('}') + 1);
  const data = JSON.parse(jsonString);
  
  data.table.rows.forEach((row) => {
    const c = row.c;
    if (!c || !c[0]) return;
    
    const title = c[0]?.v || '';

    // Если в колонке А написано "подзаголовок", берем текст из колонки B
    if (title.toLowerCase().trim() === 'подзаголовок') {
      pageSubtitle = c[1]?.v || pageSubtitle;
      return; 
    }

    // Собираем карточки пожертвований
    if (title && !title.includes('Название') && title !== 'Title') {
      dynamicDonations.push({
        title: title,
        description: c[1]?.v || '',
        icon: c[2]?.v?.trim().toLowerCase() || 'heart',
        buttonText: c[3]?.v || 'Пожертвовать',
        badge: c[4]?.v || null
      });
    }
  });
  
} catch (error) {
  console.error('Ошибка при загрузке данных из Google Таблицы:', error);
}

// 2. БИБЛИОТЕКА ИКОНОК
const icons = {
  heart: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>`,
  home: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>`,
  candle: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" /></svg>`,
  hammer: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" /></svg>`
};
---

<Layout title="Пожертвования">
  <Header />
  
  <main class="pt-32 pb-20 px-4 max-w-7xl mx-auto min-h-screen relative z-10">
    <div class="text-center mb-16 animate-[fadeIn_0.5s_ease-out]">
      <h1 class="text-5xl md:text-6xl font-bold font-['Playfair_Display'] text-slate-950 mb-6 text-balance text-center">Помощь храму</h1>
      <div class="w-24 h-1 bg-amber-700 mx-auto rounded-full opacity-80 mb-6 shadow-inner"></div>
      
      <p class="text-lg text-slate-600 max-w-2xl mx-auto whitespace-pre-line leading-relaxed">
        {pageSubtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 lg:gap-8">
      
      <div class="bg-white rounded-[2rem] p-6 lg:p-8 border-2 border-amber-200 shadow-xl shadow-slate-200/50 flex flex-col hover:-translate-y-1 transition-transform duration-300 relative z-10">
        <div class="w-14 h-14 text-amber-800 mb-6" set:html={icons['heart']}></div>
        <h3 class="text-2xl font-bold font-['Playfair_Display'] text-slate-900 mb-4">На уставную деятельность</h3>
        <p class="text-slate-600 mb-8 flex-grow text-sm lg:text-base leading-relaxed">
          Общее пожертвование. Эти средства пойдут на оплату коммунальных услуг, труд певчих и повседневные нужды прихода.
        </p>
        <button class="w-full py-4 bg-amber-700 text-white rounded-xl font-bold hover:bg-amber-800 transition-all duration-300 shadow-md shadow-amber-700/20 active:scale-95">
          Пожертвовать
        </button>
      </div>

      {dynamicDonations.map((item) => (
        <div class={`rounded-[2rem] p-6 lg:p-8 shadow-xl flex flex-col transition-all duration-300 relative overflow-hidden z-10 
          ${item.badge 
            ? 'bg-orange-50/60 border-2 border-orange-500 shadow-orange-950/5 ring-4 ring-orange-500/10 hover:-translate-y-2 hover:shadow-2xl' 
            : 'bg-white border-2 border-amber-200 shadow-slate-200/50 hover:-translate-y-1'
          }`}>
          
          {/* БЕЙДЖИК СРОЧНО (Новый благородный терракотовый цвет жженой сиены) */}
          {item.badge && (
            <div class="absolute top-0 right-0 bg-orange-800 text-white text-xs font-bold px-4 py-2 rounded-bl-2xl rounded-tr-[1.8rem] uppercase tracking-wider shadow-md">
              {item.badge}
            </div>
          )}

          <div class={`w-14 h-14 mb-6 ${item.badge ? 'text-orange-900' : 'text-amber-800'}`} set:html={icons[item.icon] || icons['heart']}></div>
          
          <h3 class="text-2xl font-bold font-['Playfair_Display'] text-slate-900 mb-4">{item.title}</h3>
          <p class="text-slate-700 mb-8 flex-grow text-sm lg:text-base leading-relaxed">{item.description}</p>
          
          <button class={`w-full py-4 rounded-xl font-bold transition-all duration-300 shadow-sm active:scale-95 
            ${item.badge 
              ? 'bg-orange-800 text-white hover:bg-orange-950 shadow-md shadow-orange-900/30' 
              : 'bg-amber-700 text-white hover:bg-amber-800 shadow-md shadow-amber-700/20'
            }`}>
            {item.buttonText}
          </button>
        </div>
      ))}

      <div class="bg-white rounded-[2rem] p-6 lg:p-8 border-2 border-amber-200 shadow-xl shadow-slate-200/50 flex flex-col hover:-translate-y-1 transition-transform duration-300 relative z-10">
        <div class="w-14 h-14 text-amber-800 mb-6" set:html={icons['candle']}></div>
        <h3 class="text-2xl font-bold font-['Playfair_Display'] text-slate-900 mb-4">Жертва в алтарь</h3>
        <p class="text-slate-600 mb-8 flex-grow text-sm lg:text-base leading-relaxed">
          Целевое пожертвование на приобретение восковых свечей, лампадного масла и ладана для совершения богослужений.
        </p>
        <button class="w-full py-4 bg-amber-700 text-white rounded-xl font-bold hover:bg-amber-800 transition-all duration-300 shadow-md shadow-amber-700/20 active:scale-95">
          Пожертвовать
        </button>
      </div>

    </div>

    <div class="mt-12 text-center text-sm text-slate-500 max-w-2xl mx-auto relative z-10">
      Нажимая на кнопки пожертвований, вы принимаете условия 
      <a href="/oferta" class="underline hover:text-amber-700 transition-colors">Публичной оферты</a> 
      и даете согласие на обработку персональных данных в соответствии с 
      <a href="/privacy" class="underline hover:text-amber-700 transition-colors">Политикой конфиденциальности</a>.
    </div>
  </main>
</Layout>