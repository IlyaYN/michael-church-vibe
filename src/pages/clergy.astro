---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

// 1. НАСТРОЙКИ ЕДИНОЙ БАЗЫ ДАННЫХ (Берем ID Админки из сейфа .env)
const SHEET_ID = import.meta.env.GOOGLE_SHEET_ADMIN_ID;
const TAB_NAME = 'Clergy'; // Читаем именно вкладку Духовенства
const URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${TAB_NAME}`;

let clergyData = [];

try {
  // 2. УМНЫЙ ЗАПРОС И ПАРСИНГ
  const response = await fetch(URL);
  const text = await response.text();
  
  // Отрезаем лишнее, оставляем чистый JSON
  const jsonString = text.substring(text.indexOf('{'), text.lastIndexOf('}') + 1);
  const data = JSON.parse(jsonString);
  const rows = data.table.rows;
  
  // 3. ПРЕВРАЩАЕМ СТРОКИ В КАРТОЧКИ
  clergyData = rows.map((row) => {
    const c = row.c;
    return {
      name: c[0]?.v || '',
      position: c[1]?.v || '',
      image: c[2]?.v || '', 
      description: c[3]?.v || '' 
    };
  }).filter(item => item.name && !item.name.includes('Имя (ФИО)')); // Игнорируем шапку и пустые строки
  
} catch (error) {
  console.error('Ошибка при загрузке данных Духовенства:', error);
}
---

<Layout title="Духовенство">
  <Header />
  
  <main class="pt-32 pb-20 px-4 max-w-7xl mx-auto min-h-screen relative z-10">
    <div class="text-center mb-16 animate-[fadeIn_0.5s_ease-out]">
      <h1 class="text-5xl md:text-6xl font-bold font-['Playfair_Display'] text-slate-950 mb-6 text-balance text-center">Духовенство храма</h1>
      <div class="w-24 h-1 bg-amber-700 mx-auto rounded-full opacity-80 mb-6 shadow-inner"></div>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        Священнослужители нашего прихода.
      </p>
    </div>

    {clergyData.length === 0 ? (
      <div class="text-center p-10 bg-white/90 backdrop-blur-md rounded-3xl shadow-xl border border-slate-100">
        <p class="text-slate-500 text-lg font-medium">Данные о духовенстве загружаются или пока не добавлены...</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {clergyData.map((cleric) => (
          <article class="bg-white rounded-[2.5rem] p-6 md:p-8 shadow-xl border border-slate-100 hover:shadow-2xl hover:border-amber-100 transition-all duration-300 transform hover:-translate-y-1 flex flex-col gap-6 relative z-10 group overflow-hidden">
            
            {/* Блок с фотографией */}
            <div class="relative overflow-hidden rounded-[2rem] bg-amber-50 shadow-inner">
                {cleric.image ? (
                  <img 
                      src={cleric.image} 
                      alt={cleric.name} 
                      class="w-full aspect-[3/4] object-cover object-top rounded-[2rem] transition-transform duration-700 group-hover:scale-105"
                      loading="lazy"
                  />
                ) : (
                  <div class="w-full aspect-[3/4] flex items-center justify-center text-amber-800/20">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-24 h-24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                    </svg>
                  </div>
                )}
            </div>

            {/* Блок с именем и должностью */}
            <div>
                <h3 class="text-2xl font-bold text-slate-900 font-['Playfair_Display'] text-balance mb-3">{cleric.name}</h3>
                {cleric.position && (
                  <p class="text-xs font-bold text-amber-800 uppercase tracking-wider bg-amber-50 border border-amber-100 inline-block px-4 py-2 rounded-xl shadow-sm">
                      {cleric.position}
                  </p>
                )}
            </div>
            
            {/* Блок с описанием (whitespace-pre-line сохраняет все абзацы из таблицы) */}
            {cleric.description && (
              <div class="border-t border-slate-100 pt-6 mt-auto">
                  <p class="text-slate-700 leading-relaxed whitespace-pre-line text-sm font-medium">
                      {cleric.description}
                  </p>
              </div>
            )}
            
          </article>
        ))}
      </div>
    )}
  </main>
</Layout>