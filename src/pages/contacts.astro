---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

// НАСТРОЙКИ АДМИНКИ (Теперь берем ID из безопасного сейфа .env)
const SHEET_ID = import.meta.env.GOOGLE_SHEET_ADMIN_ID;
const TAB_NAME = 'Contacts'; // Новая вкладка
const URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${TAB_NAME}`;

let phones = [];
let socials = [];

// Умный определитель цвета для кнопок соцсетей
function getSocialStyles(name) {
  const n = name.toLowerCase();
  if (n.includes('вконтакте') || n.includes('vk')) return 'bg-[#0077FF] hover:bg-blue-700 shadow-blue-500/20';
  if (n.includes('telegram') || n.includes('тг')) return 'bg-[#2AABEE] hover:bg-sky-600 shadow-sky-500/20';
  if (n.includes('whatsapp') || n.includes('ватсап')) return 'bg-[#25D366] hover:bg-green-600 shadow-green-500/20';
  if (n.includes('youtube') || n.includes('ютуб')) return 'bg-[#FF0000] hover:bg-red-600 shadow-red-500/20';
  // Стандартный цвет для всех остальных (Лавка, Воскресная школа и т.д.)
  return 'bg-amber-800 hover:bg-amber-900 shadow-amber-800/20';
}

// Очистка номера телефона для ссылки (чтобы при клике звонило)
function cleanPhoneNumber(phone) {
  return phone.replace(/[^\d+]/g, '');
}

try {
  const response = await fetch(URL);
  const text = await response.text();
  const jsonString = text.substring(text.indexOf('{'), text.lastIndexOf('}') + 1);
  const data = JSON.parse(jsonString);
  
  data.table.rows.forEach(row => {
    const c = row.c;
    if (!c || !c[0]) return;
    
    const type = c[0].v?.toLowerCase().trim();
    
    if (type === 'телефон') {
      phones.push({ number: c[1]?.v || '', comment: c[2]?.v || '' });
    } else if (type === 'соцсеть') {
      socials.push({ name: c[1]?.v || '', link: c[2]?.v || '#' });
    }
  });
} catch (error) {
  console.error('Ошибка при загрузке контактов:', error);
}

// Если таблица пуста, показываем базовые данные
if (phones.length === 0) {
  phones.push({ number: '+7 (926) 649-52-35', comment: 'Ежедневно с 8:00 до 20:00' });
}
if (socials.length === 0) {
  socials.push(
    { name: 'ВКонтакте', link: 'https://vk.ru/arhangelpushkino' },
    { name: 'Telegram', link: 'https://t.me/arhangelpushkino' }
  );
}
---

<Layout title="Контакты">
  <Header />
  
  <main class="pt-32 pb-20 px-4 max-w-7xl mx-auto min-h-screen relative z-10">
    <div class="text-center mb-16 animate-[fadeIn_0.5s_ease-out]">
      <h1 class="text-5xl md:text-6xl font-bold font-['Playfair_Display'] text-slate-950 mb-6 text-balance text-center">Контакты и карта проезда</h1>
      <div class="w-24 h-1 bg-amber-700 mx-auto rounded-full opacity-80 mb-6 shadow-inner"></div>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        Как добраться до храма Архангела Михаила, телефоны и наши реквизиты.
      </p>
    </div>

    <div class="bg-white rounded-[3rem] shadow-2xl border border-slate-100 overflow-hidden flex flex-col xl:flex-row shadow-amber-800/10 hover:shadow-amber-800/20 transition-shadow duration-500">
      
      <div class="p-10 md:p-16 xl:p-20 xl:w-7/12 flex flex-col justify-center space-y-12 bg-amber-50/20 border-r border-slate-100 relative">
        <div class="absolute inset-0 opacity-5 bg-[url('/images/pattern.svg')]"></div>

        <div class="flex gap-6 items-start relative z-10">
            <div class="w-12 h-12 text-amber-800 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-amber-700 uppercase tracking-wider mb-3">Адрес для навигатора</h3>
              <p class="text-2xl text-slate-950 font-bold font-['Playfair_Display'] leading-tight xl:text-3xl">
                г. Пушкино, мкр. Заветы Ильича,<br/>
                ул. Фрунзе, д. 21
              </p>
            </div>
        </div>

        <div class="flex gap-6 items-start border-t border-slate-100 pt-10 relative z-10">
            <div class="w-12 h-12 text-amber-800 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.18-7.076-7.076l1.293-.97c.362-.271.527-.733.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
            </div>
            <div class="flex flex-col gap-6">
              {phones.map((phone) => (
                <div>
                  <h3 class="text-sm font-bold text-amber-700 uppercase tracking-wider mb-2">{phone.comment}</h3>
                  <a href={`tel:${cleanPhoneNumber(phone.number)}`} class="text-2xl text-slate-950 font-bold font-['Playfair_Display'] hover:text-amber-800 transition-colors duration-300 block leading-tight xl:text-3xl active:scale-95">
                    {phone.number}
                  </a>
                </div>
              ))}
            </div>
        </div>

        <div class="flex gap-6 items-start border-t border-slate-100 pt-10 relative z-10">
            <div class="w-12 h-12 text-amber-800 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-amber-700 uppercase tracking-wider mb-3">Полезные ссылки</h3>
              <div class="flex flex-wrap gap-4 mt-4">
                {socials.map((social) => (
                  <a href={social.link} target="_blank" rel="noopener noreferrer" class={`px-8 py-4 rounded-xl font-bold text-white transition-all duration-300 shadow-lg active:scale-95 ${getSocialStyles(social.name)}`}>
                    {social.name}
                  </a>
                ))}
              </div>
            </div>
        </div>

        <div class="flex gap-6 items-start border-t border-slate-100 pt-10 relative z-10">
            <div class="w-12 h-12 text-amber-800 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-amber-700 uppercase tracking-wider mb-3">Реквизиты организации</h3>
              <div class="text-sm text-slate-700 leading-relaxed font-medium bg-white/60 p-5 rounded-xl border border-slate-200 shadow-sm">
                <p class="font-bold text-slate-900 mb-2">МРО «Православный Приход Михаило-Архангельского Храма Мкр. Заветы Ильича г. Пушкино Сергиево-Посадской Епархии РПЦ (МП)»</p>
                <p><strong>Юр. адрес:</strong> 141254, Московская обл., мкр. Заветы Ильича, ул. Фрунзе, дом 19, строение А</p>
                <p><strong>ИНН:</strong> 5038154665 / <strong>КПП:</strong> 503801001</p>
                <p><strong>ОГРН:</strong> 1205000071561</p>
                <div class="mt-2 pt-2 border-t border-slate-200/60">
                  <p><strong>Р/с:</strong> 40703810740000007408</p>
                  <p><strong>Банк:</strong> ПАО СБЕРБАНК, <strong>БИК:</strong> 044525225</p>
                  <p><strong>К/с:</strong> 30101810400000000225</p>
                </div>
              </div>
            </div>
        </div>

      </div>

      <div class="xl:w-5/12 h-[500px] xl:h-auto min-h-[650px] relative bg-slate-100 border-l border-slate-100">
        <iframe 
          src="https://yandex.ru/map-widget/v1/?um=constructor%3Aee60249b4f342cabceee47f729b1340962636a73babf2a6cd109c89fa9bd908a&amp;source=constructor" 
          width="100%" 
          height="100%" 
          frameborder="0" 
          style="border:0;" 
          class="absolute inset-0 w-full h-full object-cover"
          title="Карта проезда к храму Архангела Михаила">
        </iframe>
      </div>

    </div>
  </main>
</Layout>