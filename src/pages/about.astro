---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

// Настройки нашей Админки (Берем ID Админки из сейфа .env)
const SHEET_ID = import.meta.env.GOOGLE_SHEET_ADMIN_ID;
const TAB_NAME = 'About'; // Читаем вкладку About
const URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${TAB_NAME}`;

let aboutBlocks = [];

try {
  const response = await fetch(URL);
  const text = await response.text();
  
  const jsonString = text.substring(text.indexOf('{'), text.lastIndexOf('}') + 1);
  const data = JSON.parse(jsonString);
  const rows = data.table.rows;
  
  aboutBlocks = rows.map((row) => {
    // ВАЖНО: ЗАЩИТА ОТ ПУСТЫХ СТРОК (ИЗ-ЗА КОТОРЫХ БЫЛ БАГ)
    const c = row.c || []; 
    
    return {
      title: c[0]?.v || '',
      text: c[1]?.v || '',
      image: c[2]?.v || null // Картинка не обязательна
    };
  }).filter(item => item.title && !item.title.includes('Заголовок')); // Игнорируем шапку и пустые строки
  
} catch (error) {
  console.error('Ошибка при загрузке данных О храме:', error);
}
---

<Layout title="О храме">
  <Header />
  
  <main class="pt-32 pb-20 px-4 max-w-5xl mx-auto min-h-screen relative z-10">
    <div class="text-center mb-16 animate-[fadeIn_0.5s_ease-out]">
      <h1 class="text-5xl md:text-6xl font-bold font-['Playfair_Display'] text-slate-950 mb-6 text-balance text-center">О храме</h1>
      <div class="w-24 h-1 bg-amber-700 mx-auto rounded-full opacity-80 mb-6 shadow-inner"></div>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        История нашего прихода, святыни и духовная жизнь общины.
      </p>
    </div>

    {aboutBlocks.length === 0 ? (
      <div class="text-center p-10 bg-white/90 backdrop-blur-md rounded-3xl shadow-xl border border-slate-100">
        <p class="text-slate-500 text-lg font-medium">Информация загружается...</p>
      </div>
    ) : (
      <div class="space-y-12 md:space-y-20">
        {aboutBlocks.map((block, index) => (
          <article class="bg-white rounded-[3rem] p-8 md:p-12 shadow-xl border border-slate-100 flex flex-col gap-8 relative overflow-hidden group hover:shadow-2xl hover:border-amber-100 transition-all duration-500">
            
            {/* Фоновый узор для красоты */}
            <div class="absolute top-0 right-0 w-64 h-64 opacity-5 mix-blend-multiply transition-transform duration-700 group-hover:scale-105 pointer-events-none">
                <img src="/images/sketch-1.png" alt="" class="w-full h-full object-cover">
            </div>

            <h2 class="text-3xl md:text-4xl font-bold font-['Playfair_Display'] text-slate-900 relative z-10">
              {block.title}
            </h2>

            <div class={`relative z-10 flex flex-col ${block.image ? 'lg:flex-row' : ''} gap-10`}>
              
              {/* Если есть картинка, выводим её */}
              {block.image && (
                <div class="lg:w-1/2 shrink-0">
                  <div class="rounded-3xl overflow-hidden shadow-md border border-slate-100 bg-amber-50">
                    <img 
                      src={block.image} 
                      alt={block.title} 
                      class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                </div>
              )}

              {/* Текст */}
              <div class={`prose prose-lg prose-slate max-w-none ${block.image ? 'lg:w-1/2' : 'w-full'} text-slate-700 whitespace-pre-line leading-relaxed`}>
                {block.text}
              </div>

            </div>
          </article>
        ))}
      </div>
    )}
  </main>
</Layout>